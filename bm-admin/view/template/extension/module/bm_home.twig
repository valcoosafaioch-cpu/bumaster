{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-bm-home" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary">
          <i class="fa fa-save"></i>
        </button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default">
          <i class="fa fa-reply"></i>
        </a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
      <div class="alert alert-danger alert-dismissible">
        <i class="fa fa-exclamation-circle"></i> {{ error_warning }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endif %}

    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title">
          <i class="fa fa-home"></i> {{ text_edit }}
        </h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-bm-home" class="form-horizontal">
          <ul class="nav nav-tabs">
            <li class="{% if active_tab != 'a5' %}active{% endif %}">
              <a href="#tab-contacts" data-toggle="tab">{{ tab_contacts }}</a>
            </li>
            <li class="{% if active_tab == 'a5' %}active{% endif %}">
              <a href="#tab-text" data-toggle="tab">{{ tab_text }}</a>
            </li>
            <li>
              <a href="#tab-banner" data-toggle="tab">{{ tab_banner }}</a>
            </li>
            <li>
              <a href="#tab-slides" data-toggle="tab">{{ tab_slides }}</a>
            </li>
          </ul>

          <div class="tab-content">

            {# --- Вкладка "Контакты" --- #}
            <div class="tab-pane {% if active_tab != 'a5' %}active{% endif %}" id="tab-contacts">
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-telegram-group">{{ entry_telegram_group }}</label>
                <div class="col-sm-10">
                  <input type="text"
                         name="bm_home_telegram_group"
                         value="{{ bm_home_telegram_group }}"
                         placeholder="{{ entry_telegram_group }}"
                         id="input-telegram-group"
                         class="form-control" />
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_telegram_group_image }}</label>
                <div class="col-sm-10">
                  <a href="" id="thumb-telegram-group-image" data-toggle="image" class="img-thumbnail">
                    <img src="{{ bm_home_telegram_group_image_thumb }}"
                         alt=""
                         title=""
                         data-placeholder="{{ placeholder }}" />
                  </a>
                  <input type="hidden"
                         name="bm_home_telegram_group_image"
                         value="{{ bm_home_telegram_group_image }}"
                         id="input-telegram-group-image" />
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-telegram-dm">{{ entry_telegram_dm }}</label>
                <div class="col-sm-10">
                  <input type="text"
                         name="bm_home_telegram_dm"
                         value="{{ bm_home_telegram_dm }}"
                         placeholder="{{ entry_telegram_dm }}"
                         id="input-telegram-dm"
                         class="form-control" />
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_telegram_dm_icon }}</label>
                <div class="col-sm-10">
                  <a href="" id="thumb-telegram-dm-icon" data-toggle="image" class="img-thumbnail">
                    <img src="{{ bm_home_telegram_dm_icon_thumb }}"
                         alt=""
                         title=""
                         data-placeholder="{{ placeholder }}" />
                  </a>
                  <input type="hidden"
                         name="bm_home_telegram_dm_icon"
                         value="{{ bm_home_telegram_dm_icon }}"
                         id="input-telegram-dm-icon" />
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-vk-group">{{ entry_vk_group }}</label>
                <div class="col-sm-10">
                  <input type="text"
                         name="bm_home_vk_group"
                         value="{{ bm_home_vk_group }}"
                         placeholder="{{ entry_vk_group }}"
                         id="input-vk-group"
                         class="form-control" />
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_vk_group_image }}</label>
                <div class="col-sm-10">
                  <a href="" id="thumb-vk-group-image" data-toggle="image" class="img-thumbnail">
                    <img src="{{ bm_home_vk_group_image_thumb }}"
                         alt=""
                         title=""
                         data-placeholder="{{ placeholder }}" />
                  </a>
                  <input type="hidden"
                         name="bm_home_vk_group_image"
                         value="{{ bm_home_vk_group_image }}"
                         id="input-vk-group-image" />
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-email">{{ entry_email }}</label>
                <div class="col-sm-10">
                  <input type="text"
                         name="bm_home_email"
                         value="{{ bm_home_email }}"
                         placeholder="{{ entry_email }}"
                         id="input-email"
                         class="form-control" />
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-contact-link">{{ entry_contact_link }}</label>
                <div class="col-sm-10">
                  <input type="text"
                         name="bm_home_contact_link"
                         value="{{ bm_home_contact_link }}"
                         placeholder="{{ entry_contact_link }}"
                         id="input-contact-link"
                         class="form-control" />
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-delivery-link">{{ entry_delivery_link }}</label>
                <div class="col-sm-10">
                  <input type="text"
                         name="bm_home_delivery_link"
                         value="{{ bm_home_delivery_link }}"
                         placeholder="{{ entry_delivery_link }}"
                         id="input-delivery-link"
                         class="form-control" />
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-about-link">{{ entry_about_link }}</label>
                <div class="col-sm-10">
                  <input type="text"
                         name="bm_home_about_link"
                         value="{{ bm_home_about_link }}"
                         placeholder="{{ entry_about_link }}"
                         id="input-about-link"
                         class="form-control" />
                </div>
              </div>
            </div>

            {# --- Вкладка "Новости A5" --- #}
            <div class="tab-pane {% if active_tab == 'a5' %}active{% endif %}" id="tab-text">
              <div class="row">
                <div class="col-sm-12">
                  <h4 style="margin-top: 0;">{{ tab_text }}</h4>
                  <p class="help-block" style="margin-bottom: 20px;">
                    {{ help_news }}
                  </p>
                </div>
              </div>

              <div class="row">
                <div class="col-sm-12">
                  <div class="panel panel-default">
                    <div class="panel-heading">
                      <h3 class="panel-title"><i class="fa fa-plus-circle"></i> {{ button_add_news }}</h3>
                    </div>
                    <div class="panel-body">
                      <form action="{{ action }}" method="post" id="form-bm-home-news-add" class="form-horizontal">
                        <input type="hidden" name="bm_home_news_action" value="save_news" />
                        <input type="hidden" name="bm_home_news_id" value="0" />

                        <div class="form-group">
                          <label class="col-sm-2 control-label" for="input-news-title-new">{{ entry_news_title }}</label>
                          <div class="col-sm-10">
                            <input type="text"
                                   name="bm_home_news_title"
                                   value=""
                                   id="input-news-title-new"
                                   class="form-control" />
                          </div>
                        </div>

                        <div class="form-group">
                          <label class="col-sm-2 control-label" for="input-news-tag-new">{{ entry_news_tag }}</label>
                          <div class="col-sm-4">
                            <select name="bm_home_news_tag" id="input-news-tag-new" class="form-control">
                              {% for news_tag in bm_home_news_tags %}
                                <option value="{{ news_tag }}">{{ news_tag }}</option>
                              {% endfor %}
                            </select>
                          </div>
                        </div>

                        <div class="form-group">
                          <label class="col-sm-2 control-label" for="input-news-short-new">{{ entry_news_short_text }}</label>
                          <div class="col-sm-10">
                            <textarea name="bm_home_news_short_text"
                                      rows="10"
                                      id="input-news-short-new"
                                      class="form-control summernote"
                                      data-toggle="summernote"></textarea>
                          </div>
                        </div>

                        <div class="form-group">
                          <label class="col-sm-2 control-label" for="input-news-full-new">{{ entry_news_full_text }}</label>
                          <div class="col-sm-10">
                            <textarea name="bm_home_news_full_text"
                                      rows="14"
                                      id="input-news-full-new"
                                      class="form-control summernote"
                                      data-toggle="summernote"></textarea>
                          </div>
                        </div>

                        <div class="text-right">
                          <button type="submit" class="btn btn-primary">
                            <i class="fa fa-save"></i> {{ button_save_news }}
                          </button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>
              </div>

              {% if bm_home_news %}
                {% for news in bm_home_news %}
                  <div class="row">
                    <div class="col-sm-12">
                      <div class="panel panel-default">
                        <div class="panel-heading clearfix">
                          <h3 class="panel-title pull-left" style="padding-top: 8px;">
                            <i class="fa fa-newspaper-o"></i>
                            {{ news.date_news }} — {{ news.title }}
                          </h3>
                        </div>
                        <div class="panel-body">
                          <form action="{{ action }}" method="post" class="form-horizontal">
                            <input type="hidden" name="bm_home_news_action" value="save_news" />
                            <input type="hidden" name="bm_home_news_id" value="{{ news.news_id }}" />

                            <div class="form-group">
                              <label class="col-sm-2 control-label" for="input-news-title-{{ news.news_id }}">{{ entry_news_title }}</label>
                              <div class="col-sm-10">
                                <input type="text"
                                       name="bm_home_news_title"
                                       value="{{ news.title }}"
                                       id="input-news-title-{{ news.news_id }}"
                                       class="form-control" />
                              </div>
                            </div>

                            <div class="form-group">
                              <label class="col-sm-2 control-label" for="input-news-tag-{{ news.news_id }}">{{ entry_news_tag }}</label>
                              <div class="col-sm-4">
                                <select name="bm_home_news_tag" id="input-news-tag-{{ news.news_id }}" class="form-control">
                                  {% for news_tag in bm_home_news_tags %}
                                    <option value="{{ news_tag }}" {% if news.tag == news_tag %}selected="selected"{% endif %}>{{ news_tag }}</option>
                                  {% endfor %}
                                </select>
                              </div>

                              <label class="col-sm-2 control-label">{{ entry_news_mail_sent }}</label>
                              <div class="col-sm-4" style="padding-top: 8px;">
                                {% if news.mail_sent %}
                                  <span class="label label-success">{{ text_mail_sent_yes }}</span>
                                {% else %}
                                  <span class="label label-default">{{ text_mail_sent_no }}</span>
                                {% endif %}
                              </div>
                            </div>

                            <div class="form-group">
                              <label class="col-sm-2 control-label">{{ entry_news_date }}</label>
                              <div class="col-sm-4" style="padding-top: 8px;">
                                {{ news.date_news }}
                              </div>
                            </div>

                            <div class="form-group">
                              <label class="col-sm-2 control-label" for="input-news-short-{{ news.news_id }}">{{ entry_news_short_text }}</label>
                              <div class="col-sm-10">
                                <textarea name="bm_home_news_short_text"
                                          rows="10"
                                          id="input-news-short-{{ news.news_id }}"
                                          class="form-control summernote"
                                          data-toggle="summernote">{{ news.short_text }}</textarea>
                              </div>
                            </div>

                            <div class="form-group">
                              <label class="col-sm-2 control-label" for="input-news-full-{{ news.news_id }}">{{ entry_news_full_text }}</label>
                              <div class="col-sm-10">
                                <textarea name="bm_home_news_full_text"
                                          rows="14"
                                          id="input-news-full-{{ news.news_id }}"
                                          class="form-control summernote"
                                          data-toggle="summernote">{{ news.full_text }}</textarea>
                              </div>
                            </div>

                            <div class="text-right" style="display: flex; gap: 10px; justify-content: flex-end;">
                              <button type="submit" class="btn btn-primary">
                                <i class="fa fa-save"></i> Сохранить
                              </button>
                            </div>
                          </form>

                          <form action="{{ action }}" method="post" onsubmit="return confirm('Удалить эту новость?');" style="margin-top: 10px;">
                            <input type="hidden" name="bm_home_news_action" value="delete_news" />
                            <input type="hidden" name="bm_home_news_id" value="{{ news.news_id }}" />

                            <div class="text-right">
                              <button type="submit" class="btn btn-danger">
                                <i class="fa fa-trash"></i> {{ button_delete_news }}
                              </button>
                            </div>
                          </form>
                        </div>
                      </div>
                    </div>
                  </div>
                {% endfor %}
              {% else %}
                <div class="alert alert-info">
                  Новости пока не добавлены.
                </div>
              {% endif %}
            </div>

            {# --- Вкладка "Баннер A1" --- #}
            <div class="tab-pane" id="tab-banner">
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_banner_image }}</label>
                <div class="col-sm-10">
                  <a href="" id="thumb-banner" data-toggle="image" class="img-thumbnail">
                    <img src="{{ bm_home_banner_thumb }}"
                         alt=""
                         title=""
                         data-placeholder="{{ placeholder }}" />
                  </a>
                  <input type="hidden"
                         name="bm_home_banner_image"
                         value="{{ bm_home_banner_image }}"
                         id="input-banner-image" />
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-banner-link">{{ entry_banner_link }}</label>
                <div class="col-sm-10">
                  <input type="text"
                         name="bm_home_banner_link"
                         value="{{ bm_home_banner_link }}"
                         placeholder="{{ entry_banner_link }}"
                         id="input-banner-link"
                         class="form-control" />
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-banner-text">{{ entry_banner_text }}</label>
                <div class="col-sm-10">
                  <textarea name="bm_home_banner_text"
                            rows="5"
                            id="input-banner-text"
                            class="form-control summernote"
                            data-toggle="summernote">{{ bm_home_banner_text }}
                  </textarea>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-banner-status">{{ entry_banner_status }}</label>
                <div class="col-sm-10">
                  <select name="bm_home_banner_status"
                          id="input-banner-status"
                          class="form-control">
                    <option value="1" {% if bm_home_banner_status %}selected="selected"{% endif %}>{{ text_enabled }}</option>
                    <option value="0" {% if not bm_home_banner_status %}selected="selected"{% endif %}>{{ text_disabled }}</option>
                  </select>
                </div>
              </div>
            </div>

            {# --- Вкладка "Слайдер A6" --- #}
            <div class="tab-pane" id="tab-slides">
              <div class="table-responsive">
                <table id="slides" class="table table-striped table-bordered table-hover">
                  <thead>
                    <tr>
                      <th class="text-left">{{ entry_slide_image }}</th>
                      <th class="text-left">{{ entry_slide_title }}</th>
                      <th class="text-left">{{ entry_slide_link }}</th>
                      <th class="text-left">{{ entry_slide_status }}</th>
                      <th class="text-right">{{ entry_slide_sort_order }}</th>
                      <th class="text-right"></th>
                    </tr>
                  </thead>
                  <tbody>
                    {% set slide_row = 0 %}
                    {% for slide in bm_home_slides %}
                      <tr id="slide-row{{ slide_row }}">
                        <td class="text-left">
                          <a href="" id="thumb-image{{ slide_row }}"
                             data-toggle="image"
                             class="img-thumbnail">
                            <img src="{{ slide.thumb }}"
                                 alt=""
                                 title=""
                                 data-placeholder="{{ placeholder }}" />
                          </a>
                          <input type="hidden"
                                 name="bm_home_slides[{{ slide_row }}][image]"
                                 value="{{ slide.image }}"
                                 id="input-image{{ slide_row }}" />
                        </td>
                        <td class="text-left">
                          <input type="text"
                                 name="bm_home_slides[{{ slide_row }}][title]"
                                 value="{{ slide.title }}"
                                 class="form-control" />
                        </td>
                        <td class="text-left">
                          <input type="text"
                                 name="bm_home_slides[{{ slide_row }}][link]"
                                 value="{{ slide.link }}"
                                 class="form-control" />
                        </td>
                        <td class="text-left">
                          <select name="bm_home_slides[{{ slide_row }}][status]" class="form-control">
                            <option value="1" {% if slide.status %}selected="selected"{% endif %}>{{ text_enabled }}</option>
                            <option value="0" {% if not slide.status %}selected="selected"{% endif %}>{{ text_disabled }}</option>
                          </select>
                        </td>
                        <td class="text-right">
                          <input type="text"
                                 name="bm_home_slides[{{ slide_row }}][sort_order]"
                                 value="{{ slide.sort_order }}"
                                 class="form-control" />
                        </td>
                        <td class="text-right">
                          <button type="button"
                                  onclick="$('#slide-row{{ slide_row }}').remove();"
                                  data-toggle="tooltip"
                                  title="{{ button_remove }}"
                                  class="btn btn-danger">
                            <i class="fa fa-minus-circle"></i>
                          </button>
                        </td>
                      </tr>
                      {% set slide_row = slide_row + 1 %}
                    {% endfor %}
                  </tbody>
                  <tfoot>
                    <tr>
                      <td colspan="5"></td>
                      <td class="text-right">
                        <button type="button"
                                onclick="addSlide();"
                                data-toggle="tooltip"
                                title="{{ button_add_slide }}"
                                class="btn btn-primary">
                          <i class="fa fa-plus-circle"></i>
                        </button>
                      </td>
                    </tr>
                  </tfoot>
                </table>
              </div>
            </div>

          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script type="text/javascript"><!--
var slide_row = {{ bm_home_slides|length }};

function addSlide() {
  var html  = '<tr id="slide-row' + slide_row + '">';
  html += '  <td class="text-left">';
  html += '    <a href="" id="thumb-image' + slide_row + '" data-toggle="image" class="img-thumbnail">';
  html += '      <img src="{{ placeholder }}" alt="" title="" data-placeholder="{{ placeholder }}" />';
  html += '    </a>';
  html += '    <input type="hidden" name="bm_home_slides[' + slide_row + '][image]" value="" id="input-image' + slide_row + '" />';
  html += '  </td>';
  html += '  <td class="text-left">';
  html += '    <input type="text" name="bm_home_slides[' + slide_row + '][title]" value="" class="form-control" />';
  html += '  </td>';
  html += '  <td class="text-left">';
  html += '    <input type="text" name="bm_home_slides[' + slide_row + '][link]" value="" class="form-control" />';
  html += '  </td>';
  html += '  <td class="text-left">';
  html += '    <select name="bm_home_slides[' + slide_row + '][status]" class="form-control">';
  html += '      <option value="1" selected="selected">{{ text_enabled }}</option>';
  html += '      <option value="0">{{ text_disabled }}</option>';
  html += '    </select>';
  html += '  </td>';
  html += '  <td class="text-right">';
  html += '    <input type="text" name="bm_home_slides[' + slide_row + '][sort_order]" value="" class="form-control" />';
  html += '  </td>';
  html += '  <td class="text-right">';
  html += '    <button type="button" onclick="$(\'#slide-row' + slide_row + '\').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger">';
  html += '      <i class="fa fa-minus-circle"></i>';
  html += '    </button>';
  html += '  </td>';
  html += '</tr>';

  $('#slides tbody').append(html);

  slide_row++;
}
//--></script>

<link href="view/javascript/codemirror/lib/codemirror.css" rel="stylesheet" />
<link href="view/javascript/codemirror/theme/monokai.css" rel="stylesheet" />
<script type="text/javascript" src="view/javascript/codemirror/lib/codemirror.js"></script>
<script type="text/javascript" src="view/javascript/codemirror/lib/xml.js"></script>
<script type="text/javascript" src="view/javascript/codemirror/lib/formatting.js"></script>
<script type="text/javascript" src="view/javascript/summernote/summernote.min.js"></script>
<link href="view/javascript/summernote/summernote.min.css" rel="stylesheet" />
<script type="text/javascript" src="view/javascript/summernote/summernote-image-attributes.js"></script>
<script type="text/javascript" src="view/javascript/summernote/opencart.js"></script>