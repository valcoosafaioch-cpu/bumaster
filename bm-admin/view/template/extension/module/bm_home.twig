{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-bm-home" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary">
          <i class="fa fa-save"></i>
        </button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default">
          <i class="fa fa-reply"></i>
        </a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
      <div class="alert alert-danger alert-dismissible">
        <i class="fa fa-exclamation-circle"></i> {{ error_warning }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endif %}

    {% if success %}
      <div class="alert alert-success alert-dismissible">
        <i class="fa fa-check-circle"></i> {{ success }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endif %}

    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title">
          <i class="fa fa-home"></i> {{ text_edit }}
        </h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-bm-home" class="form-horizontal">
          <ul class="nav nav-tabs">
            <li class="{% if active_tab != 'a5' %}active{% endif %}">
              <a href="#tab-contacts" data-toggle="tab">{{ tab_contacts }}</a>
            </li>
            <li class="{% if active_tab == 'a5' %}active{% endif %}">
              <a href="#tab-text" data-toggle="tab">{{ tab_text }}</a>
            </li>
            <li>
              <a href="#tab-banner" data-toggle="tab">{{ tab_banner }}</a>
            </li>
            <li>
              <a href="#tab-slides" data-toggle="tab">{{ tab_slides }}</a>
            </li>
          </ul>

          <div class="tab-content">

            {# --- Вкладка "Контакты" --- #}
            <div class="tab-pane {% if active_tab != 'a5' %}active{% endif %}" id="tab-contacts">
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-telegram-group">{{ entry_telegram_group }}</label>
                <div class="col-sm-10">
                  <input type="text"
                         name="bm_home_telegram_group"
                         value="{{ bm_home_telegram_group }}"
                         placeholder="{{ entry_telegram_group }}"
                         id="input-telegram-group"
                         class="form-control" />
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_telegram_group_image }}</label>
                <div class="col-sm-10">
                  <a href="" id="thumb-telegram-group-image" data-toggle="image" class="img-thumbnail">
                    <img src="{{ bm_home_telegram_group_image_thumb }}"
                         alt=""
                         title=""
                         data-placeholder="{{ placeholder }}" />
                  </a>
                  <input type="hidden"
                         name="bm_home_telegram_group_image"
                         value="{{ bm_home_telegram_group_image }}"
                         id="input-telegram-group-image" />
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-telegram-dm">{{ entry_telegram_dm }}</label>
                <div class="col-sm-10">
                  <input type="text"
                         name="bm_home_telegram_dm"
                         value="{{ bm_home_telegram_dm }}"
                         placeholder="{{ entry_telegram_dm }}"
                         id="input-telegram-dm"
                         class="form-control" />
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_telegram_dm_icon }}</label>
                <div class="col-sm-10">
                  <a href="" id="thumb-telegram-dm-icon" data-toggle="image" class="img-thumbnail">
                    <img src="{{ bm_home_telegram_dm_icon_thumb }}"
                         alt=""
                         title=""
                         data-placeholder="{{ placeholder }}" />
                  </a>
                  <input type="hidden"
                         name="bm_home_telegram_dm_icon"
                         value="{{ bm_home_telegram_dm_icon }}"
                         id="input-telegram-dm-icon" />
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-vk-group">{{ entry_vk_group }}</label>
                <div class="col-sm-10">
                  <input type="text"
                         name="bm_home_vk_group"
                         value="{{ bm_home_vk_group }}"
                         placeholder="{{ entry_vk_group }}"
                         id="input-vk-group"
                         class="form-control" />
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_vk_group_image }}</label>
                <div class="col-sm-10">
                  <a href="" id="thumb-vk-group-image" data-toggle="image" class="img-thumbnail">
                    <img src="{{ bm_home_vk_group_image_thumb }}"
                         alt=""
                         title=""
                         data-placeholder="{{ placeholder }}" />
                  </a>
                  <input type="hidden"
                         name="bm_home_vk_group_image"
                         value="{{ bm_home_vk_group_image }}"
                         id="input-vk-group-image" />
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-email">{{ entry_email }}</label>
                <div class="col-sm-10">
                  <input type="text"
                         name="bm_home_email"
                         value="{{ bm_home_email }}"
                         placeholder="{{ entry_email }}"
                         id="input-email"
                         class="form-control" />
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-contact-link">{{ entry_contact_link }}</label>
                <div class="col-sm-10">
                  <input type="text"
                         name="bm_home_contact_link"
                         value="{{ bm_home_contact_link }}"
                         placeholder="{{ entry_contact_link }}"
                         id="input-contact-link"
                         class="form-control" />
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-delivery-link">{{ entry_delivery_link }}</label>
                <div class="col-sm-10">
                  <input type="text"
                         name="bm_home_delivery_link"
                         value="{{ bm_home_delivery_link }}"
                         placeholder="{{ entry_delivery_link }}"
                         id="input-delivery-link"
                         class="form-control" />
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-about-link">{{ entry_about_link }}</label>
                <div class="col-sm-10">
                  <input type="text"
                         name="bm_home_about_link"
                         value="{{ bm_home_about_link }}"
                         placeholder="{{ entry_about_link }}"
                         id="input-about-link"
                         class="form-control" />
                </div>
              </div>
            </div>

            {# --- Вкладка "Новости A5" --- #}
            <div class="tab-pane {% if active_tab == 'a5' %}active{% endif %}" id="tab-text">
              <div class="row">
                <div class="col-sm-12">
                  <h4 style="margin-top: 0;">{{ tab_text }}</h4>
                  <p class="help-block" style="margin-bottom: 20px;">
                    {{ help_news }}
                  </p>
                </div>
              </div>

              <div class="row">
                <div class="col-sm-12">
                  <div class="panel panel-default">
                    <div class="panel-heading">
                      <h3 class="panel-title">
                        <a href="javascript:void(0);"
                          id="toggle-add-news-form"
                          style="display: block; color: inherit; text-decoration: none;">
                          <i class="fa fa-plus-circle"></i> {{ button_add_news }}
                        </a>
                      </h3>
                    </div>

                    <div class="panel-body" id="add-news-form-wrap" style="display: none;">
                      <form action="{{ action }}" method="post" id="form-bm-home-news-add" class="form-horizontal">
                        <input type="hidden" name="bm_home_news_action" value="save_news" />
                        <input type="hidden" name="bm_home_news_id" value="0" />

                        <div class="form-group">
                          <label class="col-sm-2 control-label" for="input-news-title-new">{{ entry_news_title }}</label>
                          <div class="col-sm-10">
                            <input type="text"
                                  name="bm_home_news_title"
                                  value=""
                                  id="input-news-title-new"
                                  class="form-control" />
                          </div>
                        </div>

                        <div class="form-group">
                          <label class="col-sm-2 control-label" for="input-news-tag-new">{{ entry_news_tag }}</label>
                          <div class="col-sm-4">
                            <select name="bm_home_news_tag" id="input-news-tag-new" class="form-control">
                              {% for news_tag in bm_home_news_tags %}
                                <option value="{{ news_tag }}">{{ news_tag }}</option>
                              {% endfor %}
                            </select>
                          </div>
                        </div>

                        <div class="form-group">
                          <label class="col-sm-2 control-label" for="input-news-short-new">{{ entry_news_short_text }}</label>
                          <div class="col-sm-10">
                            <textarea name="bm_home_news_short_text"
                                      rows="10"
                                      id="input-news-short-new"
                                      class="form-control summernote bm-news-short-editor"
                                      data-toggle="summernote"
                                      style="resize: none;"></textarea>
                          </div>
                        </div>

                        <div class="form-group">
                          <label class="col-sm-2 control-label" for="input-news-full-new">{{ entry_news_full_text }}</label>
                          <div class="col-sm-10">
                            <textarea name="bm_home_news_full_text"
                                      rows="14"
                                      id="input-news-full-new"
                                      class="form-control summernote"
                                      data-toggle="summernote"></textarea>
                          </div>
                        </div>

                        <div class="text-right">
                          <button type="submit" class="btn btn-primary">
                            <i class="fa fa-save"></i> {{ button_save_news }}
                          </button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>
              </div>

              {% if bm_home_news %}
                {% for news in bm_home_news %}
                  <div class="row">
                    <div class="col-sm-12">
                      <div class="panel panel-default">
                        <div class="panel-heading clearfix">
                          <div class="pull-left">
                            <h3 class="panel-title" style="margin: 0 0 6px 0;">
                              <i class="fa fa-newspaper-o"></i>
                              {{ news.date_news }} — {{ news.title }}
                            </h3>

                            <div>
                              <span class="js-news-mail-status-static">
                                {% if news.mail_sent == 0 %}
                                  <span class="label label-default">{{ entry_news_mail_sent }}: Рассылка не формировалась</span>

                                  {% if news.mail_prompt_hidden == 1 %}
                                    <button type="button"
                                            class="btn btn-default btn-xs js-news-mail-prompt-toggle"
                                            data-news-id="{{ news.news_id }}"
                                            aria-expanded="false"
                                            title="Показать блок отправки"
                                            style="margin-left: 6px; padding: 1px 6px; line-height: 1.2; vertical-align: middle;">
                                      <i class="fa fa-chevron-down" id="news-mail-prompt-icon-{{ news.news_id }}"></i>
                                    </button>
                                  {% endif %}
                                {% elseif news.mail_sent == 1 %}
                                  <span class="label label-success">{{ entry_news_mail_sent }}: Рассылка отправлена успешно</span>
                                {% elseif news.mail_sent == 2 %}
                                  <span class="label label-warning">{{ entry_news_mail_sent }}: Рассылка отправлена частично</span>
                                {% elseif news.mail_sent == 3 %}
                                  <span class="label label-danger">{{ entry_news_mail_sent }}: Ошибка отправки рассылки</span>
                                {% elseif news.mail_sent == 4 %}
                                  <span class="label label-primary">{{ entry_news_mail_sent }}: Рассылка в процессе отправки</span>
                                {% endif %}

                                {% if news.send_attempts_count > 0 %}
                                  <button type="button"
                                          class="btn btn-default btn-xs js-news-download-log"
                                          data-news-id="{{ news.news_id }}"
                                          data-toggle="tooltip"
                                          title="Скачать лог"
                                          style="display: inline-block; margin-left: 8px; vertical-align: middle; padding: 2px 6px;">
                                    <i class="fa fa-file-text-o"></i>
                                  </button>
                                {% endif %}

                                {% if news.send_attempts_count > 1 %}
                                  <button type="button"
                                          class="btn btn-default btn-xs js-news-attempts-toggle"
                                          data-news-id="{{ news.news_id }}"
                                          aria-expanded="false"
                                          style="display: inline-block; margin-left: 8px; vertical-align: middle; padding: 2px 6px;">
                                    <i class="fa fa-chevron-down" id="news-attempts-icon-{{ news.news_id }}"></i>
                                    Попытки рассылки ({{ news.send_attempts_count }})
                                  </button>
                                {% endif %}

                                {% if news.mail_sent == 4 %}
                                  <div style="margin-top: 6px; font-size: 12px; color: #666;">
                                    {{ news.mail_total_count }} покупателей{% if news.mail_started_at %}; Начало рассылки: {{ news.mail_started_at }}{% endif %}
                                  </div>
                                {% elseif news.mail_sent == 1 %}
                                  <div style="margin-top: 6px; font-size: 12px; color: #666;">
                                    Отправлено {{ news.mail_success_count }} из {{ news.mail_total_count }}
                                    {% if news.mail_started_at %}; Начало рассылки: {{ news.mail_started_at }}{% endif %}
                                    {% if news.mail_completed_at %}; Завершение рассылки: {{ news.mail_completed_at }}{% endif %}
                                  </div>
                                {% elseif news.mail_sent == 2 %}
                                  <div style="margin-top: 6px; font-size: 12px; color: #666;">
                                    Отправлено {{ news.mail_success_count }} из {{ news.mail_total_count }}
                                    {% if news.mail_started_at %}; Начало рассылки: {{ news.mail_started_at }}{% endif %}
                                    {% if news.mail_completed_at %}; Завершение рассылки: {{ news.mail_completed_at }}{% endif %}
                                  </div>
                                {% elseif news.mail_sent == 3 %}
                                  <div style="margin-top: 6px; font-size: 12px; color: #666;">
                                    Отправлено {{ news.mail_success_count }} из {{ news.mail_total_count }}
                                    {% if news.mail_started_at %}; Начало рассылки: {{ news.mail_started_at }}{% endif %}
                                    {% if news.mail_completed_at %}; Завершение рассылки: {{ news.mail_completed_at }}{% endif %}
                                  </div>
                                {% endif %}
                              </span>

                              <span class="js-news-mail-status-loading" style="display: none;">
                                <span class="label label-primary">{{ entry_news_mail_sent }}: В процессе отправки...</span>
                              </span>
                            </div>
                          </div>

                          <div class="pull-right text-right">
                            {% if news.mail_sent == 0 %}
                              <button type="button"
                                      class="btn btn-primary btn-sm js-news-edit-open"
                                      data-news-id="{{ news.news_id }}">
                                <i class="fa fa-pencil"></i> Редактировать
                              </button>
                            {% else %}
                              <button type="button"
                                      class="btn btn-default btn-sm"
                                      disabled="disabled"
                                      title="После запуска рассылки редактирование недоступно">
                                <i class="fa fa-lock"></i> Редактирование недоступно
                              </button>
                            {% endif %}

                            <div id="news-toggle-wrap-{{ news.news_id }}" style="margin-top: 6px;">
                              <button type="button"
                                      class="btn btn-default btn-xs js-news-view-toggle"
                                      data-news-id="{{ news.news_id }}"
                                      aria-expanded="false"
                                      style="min-width: 34px;">
                                <i class="fa fa-chevron-down" id="news-toggle-icon-{{ news.news_id }}"></i>
                              </button>
                            </div>
                          </div>
                        </div>

                        {% if news.mail_sent == 0 %}
                          <div class="panel-body js-news-mail-prompt-wrap"
                              id="news-mail-prompt-{{ news.news_id }}"
                              style="border-top: 1px solid #eee; background: #fcfcfc;{% if news.mail_prompt_hidden == 1 %} display: none;{% endif %}">
                            <div class="alert alert-info" style="margin-bottom: 15px;">
                              Новость сохранена. Рассылка ещё не запускалась.
                            </div>

                            <div style="margin-bottom: 12px;">
                              <strong>Отправить покупателям с активной рассылкой?</strong><br />
                              {{ news.subscriber_count }} из {{ news.customer_count }} покупателей подписаны на рассылку.
                            </div>

                            <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
                              <button type="button"
                                      class="btn btn-success js-news-send-confirm"
                                      data-news-id="{{ news.news_id }}">
                                <i class="fa fa-envelope"></i> Подтвердить отправку
                              </button>

                              <button type="button"
                                      class="btn btn-default js-news-send-decline"
                                      data-news-id="{{ news.news_id }}">
                                <i class="fa fa-times"></i> Не отправлять
                              </button>
                            </div>
                          </div>
                        {% endif %}

                        {% if (news.mail_sent == 2 or news.mail_sent == 3) and news.retry_fail_count > 0 %}
                          <div class="panel-body" style="border-top: 1px solid #eee; background: #fffaf2;">
                            <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
                              <button type="button"
                                      class="btn btn-warning btn-sm js-news-retry-open"
                                      data-news-id="{{ news.news_id }}">
                                <i class="fa fa-refresh"></i> Отправить рассылку повторно
                              </button>
                            </div>

                            <div id="news-retry-confirm-{{ news.news_id }}"
                                 style="display: none; margin-top: 12px;">
                              <div class="alert alert-warning" style="margin-bottom: 15px;">
                                Отправить повторно тем, кому письмо не было доставлено?
                              </div>

                              <div style="margin-bottom: 12px;">
                                {{ news.retry_fail_count }} из {{ news.mail_total_count }} покупателей не получили рассылку.
                              </div>

                              <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
                                <button type="button"
                                        class="btn btn-warning js-news-send-retry-confirm"
                                        data-news-id="{{ news.news_id }}">
                                  <i class="fa fa-envelope"></i> Подтвердить повторную отправку
                                </button>

                                <button type="button"
                                        class="btn btn-default js-news-retry-cancel"
                                        data-news-id="{{ news.news_id }}">
                                  <i class="fa fa-times"></i> Отмена
                                </button>
                              </div>
                            </div>
                          </div>
                        {% endif %}

                        {% if news.send_attempts_count > 1 %}
                          <div class="panel-body" id="news-attempts-{{ news.news_id }}" style="display: none; border-top: 1px solid #eee; background: #fafafa;">
                            {% for attempt in news.send_attempts %}
                              <div style="padding: 8px 0; border-top: {% if loop.first %}0{% else %}1px solid #eee{% endif %}; display: flex; align-items: center; justify-content: space-between; gap: 10px;">
                                <div>
                                  Попытка {{ loop.index }}
                                  (отправлено {{ attempt.success_count }} из {{ attempt.total_count }}
                                  {% if attempt.started_at %}; Начало: {{ attempt.started_at }}{% endif %}
                                  {% if attempt.completed_at %}; Завершение: {{ attempt.completed_at }}{% endif %})
                                </div>

                                <button type="button"
                                        class="btn btn-default btn-xs js-news-download-attempt-log"
                                        data-news-id="{{ news.news_id }}"
                                        data-send-id="{{ attempt.send_id }}"
                                        data-toggle="tooltip"
                                        title="Скачать лог"
                                        style="padding: 2px 6px; flex: 0 0 auto;">
                                  <i class="fa fa-file-text-o"></i>
                                </button>
                              </div>
                            {% endfor %}
                          </div>
                        {% endif %}

                        <div class="panel-body" id="news-view-{{ news.news_id }}" style="display: none;">
                          <div class="row" style="margin-bottom: 15px;">
                            <div class="col-sm-2"><strong>{{ entry_news_tag }}</strong></div>
                            <div class="col-sm-10">{{ news.tag }}</div>
                          </div>

                          <div class="row" style="margin-bottom: 15px;">
                            <div class="col-sm-2"><strong>{{ entry_news_date }}</strong></div>
                            <div class="col-sm-10">{{ news.date_news }}</div>
                          </div>

                          <div class="row" style="margin-bottom: 20px;">
                            <div class="col-sm-2"><strong>{{ entry_news_short_text }}</strong></div>
                            <div class="col-sm-10">
                              <div class="well well-sm" style="margin-bottom: 0; background: #fff; width: 900px; min-height: 180px; max-height: 180px; overflow-y: auto;">
                                {{ news.short_text|raw }}
                              </div>
                            </div>
                          </div>

                          {% if news.full_text|trim %}
                            <div class="row" style="margin-bottom: 20px;">
                              <div class="col-sm-2"><strong>{{ entry_news_full_text }}</strong></div>
                              <div class="col-sm-10">
                                <div class="well well-sm" style="margin-bottom: 0; background: #fff;">
                                  {{ news.full_text|raw }}
                                </div>
                              </div>
                            </div>
                          {% endif %}
                        </div>

                        <div class="panel-body" id="news-edit-{{ news.news_id }}" style="display: none;">
                          <form action="{{ action }}" method="post" class="form-horizontal" id="form-bm-home-news-edit-{{ news.news_id }}">
                            <input type="hidden" name="bm_home_news_action" value="save_news" />
                            <input type="hidden" name="bm_home_news_id" value="{{ news.news_id }}" />

                            <div class="form-group">
                              <label class="col-sm-2 control-label" for="input-news-title-{{ news.news_id }}">{{ entry_news_title }}</label>
                              <div class="col-sm-10">
                                <input type="text"
                                      name="bm_home_news_title"
                                      value="{{ news.title }}"
                                      id="input-news-title-{{ news.news_id }}"
                                      class="form-control" />
                              </div>
                            </div>

                            <div class="form-group">
                              <label class="col-sm-2 control-label" for="input-news-tag-{{ news.news_id }}">{{ entry_news_tag }}</label>
                              <div class="col-sm-4">
                                <select name="bm_home_news_tag" id="input-news-tag-{{ news.news_id }}" class="form-control">
                                  {% for news_tag in bm_home_news_tags %}
                                    <option value="{{ news_tag }}" {% if news.tag == news_tag %}selected="selected"{% endif %}>{{ news_tag }}</option>
                                  {% endfor %}
                                </select>
                              </div>
                            </div>

                            <div class="form-group">
                              <label class="col-sm-2 control-label">{{ entry_news_date }}</label>
                              <div class="col-sm-4" style="padding-top: 8px;">
                                {{ news.date_news }}
                              </div>
                            </div>

                            <div class="form-group">
                              <label class="col-sm-2 control-label" for="input-news-short-{{ news.news_id }}">{{ entry_news_short_text }}</label>
                              <div class="col-sm-10">
                                <textarea name="bm_home_news_short_text"
                                          rows="10"
                                          id="input-news-short-{{ news.news_id }}"
                                          class="form-control summernote bm-news-short-editor"
                                          data-toggle="summernote"
                                          style="resize: none;">{{ news.short_text }}</textarea>
                              </div>
                            </div>

                            <div class="form-group">
                              <label class="col-sm-2 control-label" for="input-news-full-{{ news.news_id }}">{{ entry_news_full_text }}</label>
                              <div class="col-sm-10">
                                <textarea name="bm_home_news_full_text"
                                          rows="14"
                                          id="input-news-full-{{ news.news_id }}"
                                          class="form-control summernote"
                                          data-toggle="summernote">{{ news.full_text }}</textarea>
                              </div>
                            </div>                         
                          </form>
                          <div class="text-right" style="display: flex; gap: 10px; justify-content: flex-end; margin-top: 15px;">
                            <form action="{{ action }}" method="post" onsubmit="return confirm('Удалить эту новость?');" style="display: inline-block; margin: 0;">
                              <input type="hidden" name="bm_home_news_action" value="delete_news" />
                              <input type="hidden" name="bm_home_news_id" value="{{ news.news_id }}" />

                              <button type="submit" class="btn btn-danger">
                                <i class="fa fa-trash"></i> {{ button_delete_news }}
                              </button>
                            </form>

                            <button type="button"
                                    class="btn btn-default js-news-edit-cancel"
                                    data-news-id="{{ news.news_id }}">
                              <i class="fa fa-reply"></i> Отмена
                            </button>

                            {% if news.mail_sent == 0 %}
                              <button type="submit"
                                      class="btn btn-primary"
                                      form="form-bm-home-news-edit-{{ news.news_id }}">
                                <i class="fa fa-save"></i> Сохранить
                              </button>
                            {% else %}
                              <button type="button"
                                      class="btn btn-default"
                                      disabled="disabled">
                                <i class="fa fa-lock"></i> Сохранение недоступно
                              </button>
                            {% endif %}
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                {% endfor %}
              {% else %}
                <div class="alert alert-info">
                  Новости пока не добавлены.
                </div>
              {% endif %}
            </div>

            {# --- Вкладка "Баннер A1" --- #}
            <div class="tab-pane" id="tab-banner">
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_banner_image }}</label>
                <div class="col-sm-10">
                  <a href="" id="thumb-banner" data-toggle="image" class="img-thumbnail">
                    <img src="{{ bm_home_banner_thumb }}"
                         alt=""
                         title=""
                         data-placeholder="{{ placeholder }}" />
                  </a>
                  <input type="hidden"
                         name="bm_home_banner_image"
                         value="{{ bm_home_banner_image }}"
                         id="input-banner-image" />
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-banner-link">{{ entry_banner_link }}</label>
                <div class="col-sm-10">
                  <input type="text"
                         name="bm_home_banner_link"
                         value="{{ bm_home_banner_link }}"
                         placeholder="{{ entry_banner_link }}"
                         id="input-banner-link"
                         class="form-control" />
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-banner-text">{{ entry_banner_text }}</label>
                <div class="col-sm-10">
                  <textarea name="bm_home_banner_text"
                            rows="5"
                            id="input-banner-text"
                            class="form-control summernote"
                            data-toggle="summernote">{{ bm_home_banner_text }}
                  </textarea>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-banner-status">{{ entry_banner_status }}</label>
                <div class="col-sm-10">
                  <select name="bm_home_banner_status"
                          id="input-banner-status"
                          class="form-control">
                    <option value="1" {% if bm_home_banner_status %}selected="selected"{% endif %}>{{ text_enabled }}</option>
                    <option value="0" {% if not bm_home_banner_status %}selected="selected"{% endif %}>{{ text_disabled }}</option>
                  </select>
                </div>
              </div>
            </div>

            {# --- Вкладка "Слайдер A6" --- #}
            <div class="tab-pane" id="tab-slides">
              <div class="table-responsive">
                <table id="slides" class="table table-striped table-bordered table-hover">
                  <thead>
                    <tr>
                      <th class="text-left">{{ entry_slide_image }}</th>
                      <th class="text-left">{{ entry_slide_title }}</th>
                      <th class="text-left">{{ entry_slide_link }}</th>
                      <th class="text-left">{{ entry_slide_status }}</th>
                      <th class="text-right">{{ entry_slide_sort_order }}</th>
                      <th class="text-right"></th>
                    </tr>
                  </thead>
                  <tbody>
                    {% set slide_row = 0 %}
                    {% for slide in bm_home_slides %}
                      <tr id="slide-row{{ slide_row }}">
                        <td class="text-left">
                          <a href="" id="thumb-image{{ slide_row }}"
                             data-toggle="image"
                             class="img-thumbnail">
                            <img src="{{ slide.thumb }}"
                                 alt=""
                                 title=""
                                 data-placeholder="{{ placeholder }}" />
                          </a>
                          <input type="hidden"
                                 name="bm_home_slides[{{ slide_row }}][image]"
                                 value="{{ slide.image }}"
                                 id="input-image{{ slide_row }}" />
                        </td>
                        <td class="text-left">
                          <input type="text"
                                 name="bm_home_slides[{{ slide_row }}][title]"
                                 value="{{ slide.title }}"
                                 class="form-control" />
                        </td>
                        <td class="text-left">
                          <input type="text"
                                 name="bm_home_slides[{{ slide_row }}][link]"
                                 value="{{ slide.link }}"
                                 class="form-control" />
                        </td>
                        <td class="text-left">
                          <select name="bm_home_slides[{{ slide_row }}][status]" class="form-control">
                            <option value="1" {% if slide.status %}selected="selected"{% endif %}>{{ text_enabled }}</option>
                            <option value="0" {% if not slide.status %}selected="selected"{% endif %}>{{ text_disabled }}</option>
                          </select>
                        </td>
                        <td class="text-right">
                          <input type="text"
                                 name="bm_home_slides[{{ slide_row }}][sort_order]"
                                 value="{{ slide.sort_order }}"
                                 class="form-control" />
                        </td>
                        <td class="text-right">
                          <button type="button"
                                  onclick="$('#slide-row{{ slide_row }}').remove();"
                                  data-toggle="tooltip"
                                  title="{{ button_remove }}"
                                  class="btn btn-danger">
                            <i class="fa fa-minus-circle"></i>
                          </button>
                        </td>
                      </tr>
                      {% set slide_row = slide_row + 1 %}
                    {% endfor %}
                  </tbody>
                  <tfoot>
                    <tr>
                      <td colspan="5"></td>
                      <td class="text-right">
                        <button type="button"
                                onclick="addSlide();"
                                data-toggle="tooltip"
                                title="{{ button_add_slide }}"
                                class="btn btn-primary">
                          <i class="fa fa-plus-circle"></i>
                        </button>
                      </td>
                    </tr>
                  </tfoot>
                </table>
              </div>
            </div>

          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script type="text/javascript"><!--
var slide_row = {{ bm_home_slides|length }};

function addSlide() {
  var html  = '<tr id="slide-row' + slide_row + '">';
  html += '  <td class="text-left">';
  html += '    <a href="" id="thumb-image' + slide_row + '" data-toggle="image" class="img-thumbnail">';
  html += '      <img src="{{ placeholder }}" alt="" title="" data-placeholder="{{ placeholder }}" />';
  html += '    </a>';
  html += '    <input type="hidden" name="bm_home_slides[' + slide_row + '][image]" value="" id="input-image' + slide_row + '" />';
  html += '  </td>';
  html += '  <td class="text-left">';
  html += '    <input type="text" name="bm_home_slides[' + slide_row + '][title]" value="" class="form-control" />';
  html += '  </td>';
  html += '  <td class="text-left">';
  html += '    <input type="text" name="bm_home_slides[' + slide_row + '][link]" value="" class="form-control" />';
  html += '  </td>';
  html += '  <td class="text-left">';
  html += '    <select name="bm_home_slides[' + slide_row + '][status]" class="form-control">';
  html += '      <option value="1" selected="selected">{{ text_enabled }}</option>';
  html += '      <option value="0">{{ text_disabled }}</option>';
  html += '    </select>';
  html += '  </td>';
  html += '  <td class="text-right">';
  html += '    <input type="text" name="bm_home_slides[' + slide_row + '][sort_order]" value="" class="form-control" />';
  html += '  </td>';
  html += '  <td class="text-right">';
  html += '    <button type="button" onclick="$(\'#slide-row' + slide_row + '\').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger">';
  html += '      <i class="fa fa-minus-circle"></i>';
  html += '    </button>';
  html += '  </td>';
  html += '</tr>';

  $('#slides tbody').append(html);

  slide_row++;
}
//--></script>
<script type="text/javascript"><!--
$('#toggle-add-news-form').on('click', function() {
  $('#add-news-form-wrap').stop(true, true).slideToggle(200);
});
//--></script>

<script type="text/javascript"><!--
function bmNewsSetToggleClosed(news_id) {
  $('#news-toggle-icon-' + news_id)
    .removeClass('fa-chevron-up')
    .addClass('fa-chevron-down');

  $('[data-news-id="' + news_id + '"].js-news-view-toggle').attr('aria-expanded', 'false');
}

function bmNewsSetToggleOpened(news_id) {
  $('#news-toggle-icon-' + news_id)
    .removeClass('fa-chevron-down')
    .addClass('fa-chevron-up');

  $('[data-news-id="' + news_id + '"].js-news-view-toggle').attr('aria-expanded', 'true');
}

function bmNewsMailPromptSetClosed(news_id) {
  $('#news-mail-prompt-icon-' + news_id)
    .removeClass('fa-chevron-up')
    .addClass('fa-chevron-down');

  $('.js-news-mail-prompt-toggle[data-news-id="' + news_id + '"]').attr('aria-expanded', 'false');
}

function bmNewsMailPromptSetOpened(news_id) {
  $('#news-mail-prompt-icon-' + news_id)
    .removeClass('fa-chevron-down')
    .addClass('fa-chevron-up');

  $('.js-news-mail-prompt-toggle[data-news-id="' + news_id + '"]').attr('aria-expanded', 'true');
}

function bmNewsPostAction(fields) {
  var $form = $('<form>', {
    method: 'post',
    action: '{{ action|replace({'&amp;': '&'}) }}',
    style: 'display:none;'
  });

  $.each(fields, function(name, value) {
    $('<input>', {
      type: 'hidden',
      name: name,
      value: value
    }).appendTo($form);
  });

  $('body').append($form);
  $form.trigger('submit');
}

$(document).on('click', '.js-news-view-toggle', function() {
  var news_id = $(this).data('news-id');
  var $view = $('#news-view-' + news_id);

  if ($view.is(':visible')) {
    $view.stop(true, true).slideUp(200);
    bmNewsSetToggleClosed(news_id);
  } else {
    $view.stop(true, true).slideDown(200);
    bmNewsSetToggleOpened(news_id);
  }
});

$(document).on('click', '.js-news-mail-prompt-toggle', function() {
  var news_id = $(this).data('news-id');
  var $wrap = $('#news-mail-prompt-' + news_id);

  if ($wrap.is(':visible')) {
    $wrap.stop(true, true).slideUp(200);
    bmNewsMailPromptSetClosed(news_id);
  } else {
    $wrap.stop(true, true).slideDown(200);
    bmNewsMailPromptSetOpened(news_id);
  }
});

$(document).on('click', '.js-news-send-confirm', function() {
  if (!confirm('Отправить рассылку по этой новости?')) {
    return;
  }

  var news_id = $(this).data('news-id');
  var $panel = $('#news-mail-prompt-' + news_id);
  var $newsPanel = $panel.closest('.panel');

  $panel.find('.js-news-send-confirm').prop('disabled', true);
  $panel.find('.js-news-send-decline').prop('disabled', true);

  $newsPanel.find('.js-news-mail-status-static').hide();
  $newsPanel.find('.js-news-mail-status-loading').show();

  bmNewsPostAction({
    bm_home_news_action: 'send_news_confirm',
    bm_home_news_id: news_id
  });
});

$(document).on('click', '.js-news-send-decline', function() {
  var news_id = $(this).data('news-id');

  bmNewsPostAction({
    bm_home_news_action: 'hide_news_mail_prompt',
    bm_home_news_id: news_id
  });
});

$(document).on('click', '.js-news-send-retry-confirm', function() {
  if (!confirm('Запустить повторную отправку только по недоставленным адресам последней попытки?')) {
    return;
  }

  var news_id = $(this).data('news-id');
  var $panel = $('#news-retry-confirm-' + news_id);
  var $newsPanel = $panel.closest('.panel');

  $panel.find('.js-news-send-retry-confirm').prop('disabled', true);
  $panel.find('.js-news-retry-cancel').prop('disabled', true);

  $newsPanel.find('.js-news-mail-status-static').hide();
  $newsPanel.find('.js-news-mail-status-loading').show();

  bmNewsPostAction({
    bm_home_news_action: 'send_news_retry_confirm',
    bm_home_news_id: news_id
  });
});

$(document).on('click', '.js-news-download-log', function() {
  var news_id = $(this).data('news-id');

  bmNewsPostAction({
    bm_home_news_action: 'download_news_log',
    bm_home_news_id: news_id
  });
});

$(document).on('click', '.js-news-download-attempt-log', function() {
  var news_id = $(this).data('news-id');
  var send_id = $(this).data('send-id');

  bmNewsPostAction({
    bm_home_news_action: 'download_news_attempt_log',
    bm_home_news_id: news_id,
    bm_home_send_id: send_id
  });
});

$(document).on('click', '.js-news-edit-open', function() {
  var news_id = $(this).data('news-id');

  $('#news-view-' + news_id).hide();
  $('#news-edit-' + news_id).stop(true, true).slideDown(200);
  $('#news-toggle-wrap-' + news_id).hide();
  bmNewsSetToggleClosed(news_id);
});

$(document).on('click', '.js-news-edit-cancel', function() {
  var news_id = $(this).data('news-id');

  $('#news-edit-' + news_id).stop(true, true).slideUp(200, function() {
    $('#news-view-' + news_id).stop(true, true).slideDown(200);
    $('#news-toggle-wrap-' + news_id).show();
    bmNewsSetToggleOpened(news_id);
  });
});


$(document).on('click', '.js-news-retry-open', function() {
  var news_id = $(this).data('news-id');

  $('#news-retry-confirm-' + news_id).stop(true, true).slideDown(200);
  $(this).prop('disabled', true);
});

$(document).on('click', '.js-news-retry-cancel', function() {
  var news_id = $(this).data('news-id');

  $('#news-retry-confirm-' + news_id).stop(true, true).slideUp(200, function() {
    $('.js-news-retry-open[data-news-id="' + news_id + '"]').prop('disabled', false);
  });
});

$(document).on('click', '.js-news-attempts-toggle', function() {
  var news_id = $(this).data('news-id');
  var $wrap = $('#news-attempts-' + news_id);
  var $icon = $('#news-attempts-icon-' + news_id);
  var is_open = $wrap.is(':visible');

  if (is_open) {
    $wrap.stop(true, true).slideUp(200);
    $icon.removeClass('fa-chevron-up').addClass('fa-chevron-down');
    $(this).attr('aria-expanded', 'false');
  } else {
    $wrap.stop(true, true).slideDown(200);
    $icon.removeClass('fa-chevron-down').addClass('fa-chevron-up');
    $(this).attr('aria-expanded', 'true');
  }
});

//--></script>



