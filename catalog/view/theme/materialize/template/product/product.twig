<script>
window.addEventListener('DOMContentLoaded', function () {
  var container = document.querySelector('.pp-feedback-rating-inputs');
  if (!container) return;

  var stars = Array.prototype.slice.call(
    container.querySelectorAll('.pp-star-btn')
  );
  var hidden = document.getElementById('pp-review-rating');
  if (!hidden) return;

  var selected = parseInt(
    hidden.value || container.getAttribute('data-current-rating') || '0',
    10
  ) || 0;

  var minRating = parseInt(
    container.getAttribute('data-min-rating') || '0',
    10
  ) || 0;

  function updateDisplay(value) {
    var v = value || 0;
    var base = Math.max(v, minRating);

    stars.forEach(function (btn) {
      var starValue = parseInt(btn.getAttribute('data-star'), 10);
      btn.classList.toggle('is-filled', starValue <= base);
    });
  }

  updateDisplay(selected);

  stars.forEach(function (btn) {
    var starValue = parseInt(btn.getAttribute('data-star'), 10);

    btn.addEventListener('mouseenter', function () {
      if (starValue < minRating) return; // ниже уже поставленной оценки не подсвечиваем
      updateDisplay(starValue);
    });

    btn.addEventListener('mouseleave', function () {
      updateDisplay(selected);
    });

    btn.addEventListener('click', function () {
      if (starValue < minRating) return; // нельзя снизить оценку
      selected = starValue;
      hidden.value = String(selected);
      updateDisplay(selected);
    });
  });
});
</script>

