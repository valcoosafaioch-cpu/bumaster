{{ header }}
{% apply spaceless %}

{% if column_left and column_right %}
	{% set main = 's12 l6' %}
{% elseif column_left or column_right %}
	{% set main = 's12 l9' %}
{% else %}
	{% set main = 's12' %}
{% endif %}

<main>
	<div class="container">

		<h1>{{ heading_title }}</h1>

		<div class="row">
			{{ column_left }}

			<div class="col {{ main }} section href-underline">
				{{ content_top }}

				<div class="pickup-points-list">
					{% for service in services %}
						<div class="card-panel pickup-point-card">
							<div class="pickup-point-card__header">
								<h2 class="pickup-point-card__title">{{ service.name }}</h2>
							</div>

							<div class="pickup-point-card__body">
								{% if service.is_selected %}
									<div class="pickup-point-card__label">{{ service.label_text }}</div>

									<div class="pickup-point-card__address">
										{{ service.address_line }}
									</div>

									{% if service.meta_line %}
										<div class="pickup-point-card__meta">
											{{ service.meta_line }}
										</div>
									{% endif %}
								{% else %}
									<div class="pickup-point-card__empty">
										{{ service.status_text }}
									</div>
								{% endif %}
							</div>

							<div class="pickup-point-card__footer">
								<button
									type="button"
									class="btn waves-effect waves-light red pickup-point-card__button js-pickup-modal-open"
									data-service-code="{{ service.code }}"
									data-service-name="{{ service.name }}"
									data-label-type="{{ service.label_type }}"
									data-modal-title="{{ service.modal_title }}"
								>
									{{ service.button_text }}
								</button>
							</div>
						</div>
					{% endfor %}
				</div>

				<div id="pickup-point-modal" class="pickup-point-modal" aria-hidden="true">
					<div class="pickup-point-modal__overlay js-pickup-modal-close"></div>

					<div class="pickup-point-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="pickup-point-modal-title">
						<div class="pickup-point-modal__header">
							<h2 id="pickup-point-modal-title" class="pickup-point-modal__title"></h2>

							<button
								type="button"
								class="pickup-point-modal__close js-pickup-modal-close"
								aria-label="{{ text_modal_close }}"
								title="{{ text_modal_close }}"
							>
								×
							</button>
						</div>

						<div class="pickup-point-modal__content">
							<div class="pickup-point-modal__search">
								<label for="pickup-point-search" class="pickup-point-modal__label">
									{{ text_modal_search_label }}
								</label>

								<input
									type="text"
									id="pickup-point-search"
									class="pickup-point-modal__input"
									value=""
									placeholder=""
								>
							</div>

							<div class="pickup-point-modal__section">
								<div class="pickup-point-modal__section-title">{{ text_modal_map_title }}</div>

								<div class="pickup-point-modal__map">
									{{ text_modal_map_stub }}
								</div>
							</div>

							<div class="pickup-point-modal__section">
								<div class="pickup-point-modal__section-title">{{ text_modal_list_title }}</div>

								<div class="pickup-point-modal__state pickup-point-modal__state--loading" style="display:none;">
									{{ text_modal_loading }}
								</div>

								<div class="pickup-point-modal__state pickup-point-modal__state--empty">
									{{ text_modal_empty }}
								</div>

								<div class="pickup-point-modal__list">
									<div class="pickup-point-modal__list-stub">
										{{ text_modal_list_stub }}
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>

				<style>
					.pickup-points-list {
						display: flex;
						flex-direction: column;
						gap: 20px;
					}

					.pickup-point-card {
						margin-bottom: 0;
					}

					.pickup-point-card__title {
						margin: 0 0 18px;
						font-size: 1.5rem;
						line-height: 1.3;
					}

					.pickup-point-card__label,
					.pickup-point-card__empty,
					.pickup-point-card__meta {
						font-size: 1rem;
						line-height: 1.5;
						color: #5f6b76;
					}

					.pickup-point-card__address {
						margin-top: 8px;
						font-size: 1.125rem;
						line-height: 1.5;
						color: #2f3a44;
					}

					.pickup-point-card__meta {
						margin-top: 8px;
					}

					.pickup-point-card__footer {
						margin-top: 20px;
						text-align: right;
					}

					.pickup-point-modal {
						position: fixed;
						inset: 0;
						z-index: 9999;
						display: none;
					}

					.pickup-point-modal.is-open {
						display: block;
					}

					.pickup-point-modal__overlay {
						position: absolute;
						inset: 0;
						background: rgba(0, 0, 0, 0.45);
					}

					.pickup-point-modal__dialog {
						position: relative;
						width: calc(100% - 32px);
						max-width: 920px;
						max-height: calc(100vh - 48px);
						margin: 24px auto;
						background: #ffffff;
						border-radius: 12px;
						overflow: hidden;
						box-shadow: 0 12px 40px rgba(0, 0, 0, 0.18);
					}

					.pickup-point-modal__header {
						display: flex;
						align-items: center;
						justify-content: space-between;
						padding: 20px 24px;
						border-bottom: 1px solid #e6e9ed;
					}

					.pickup-point-modal__title {
						margin: 0;
						font-size: 1.5rem;
						line-height: 1.3;
					}

					.pickup-point-modal__close {
						padding: 0;
						border: 0;
						background: transparent;
						font-size: 2rem;
						line-height: 1;
						cursor: pointer;
					}

					.pickup-point-modal__content {
						padding: 24px;
						overflow-y: auto;
						max-height: calc(100vh - 140px);
					}

					.pickup-point-modal__search {
						margin-bottom: 24px;
					}

					.pickup-point-modal__label {
						display: block;
						margin-bottom: 8px;
						font-weight: 600;
						color: #2f3a44;
					}

					.pickup-point-modal__input {
						width: 100%;
						height: 44px;
						padding: 0 14px;
						border: 1px solid #d7dce2;
						border-radius: 8px;
						box-sizing: border-box;
					}

					.pickup-point-modal__section + .pickup-point-modal__section {
						margin-top: 24px;
					}

					.pickup-point-modal__section-title {
						margin-bottom: 12px;
						font-size: 1.125rem;
						font-weight: 600;
						color: #2f3a44;
					}

					.pickup-point-modal__map {
						min-height: 220px;
						padding: 16px;
						border: 1px dashed #c8d0d9;
						border-radius: 10px;
						background: #fafbfc;
						color: #6e7a86;
						display: flex;
						align-items: center;
						justify-content: center;
						text-align: center;
					}

					.pickup-point-modal__state,
					.pickup-point-modal__list-stub {
						padding: 14px 16px;
						border: 1px solid #e6e9ed;
						border-radius: 10px;
						background: #fafbfc;
						color: #6e7a86;
					}

					.pickup-point-modal__list {
						margin-top: 12px;
					}

					body.pickup-modal-open {
						overflow: hidden;
					}

					@media (max-width: 767px) {
						.pickup-point-card__footer {
							text-align: left;
						}

						.pickup-point-card__button {
							width: 100%;
						}

						.pickup-point-modal__dialog {
							width: calc(100% - 16px);
							max-height: calc(100vh - 16px);
							margin: 8px auto;
						}

						.pickup-point-modal__header {
							padding: 16px;
						}

						.pickup-point-modal__content {
							padding: 16px;
							max-height: calc(100vh - 96px);
						}

						.pickup-point-modal__title {
							font-size: 1.25rem;
						}
					}
				</style>

				<script>
					document.addEventListener('DOMContentLoaded', function () {
						var modal = document.getElementById('pickup-point-modal');

						if (!modal) {
							return;
						}

						var modalTitle = document.getElementById('pickup-point-modal-title');
						var searchInput = document.getElementById('pickup-point-search');
						var openButtons = document.querySelectorAll('.js-pickup-modal-open');
						var closeButtons = document.querySelectorAll('.js-pickup-modal-close');

						function openModal(title, serviceName, labelType) {
							modal.classList.add('is-open');
							modal.setAttribute('aria-hidden', 'false');
							document.body.classList.add('pickup-modal-open');

							if (modalTitle) {
								modalTitle.textContent = title;
							}

							if (searchInput) {
								if (labelType === 'department') {
									searchInput.placeholder = 'Поиск по индексу или адресу';
								} else {
									searchInput.placeholder = 'Поиск по адресу или названию пункта';
								}

								searchInput.value = '';
								searchInput.focus();
							}

							modal.setAttribute('data-service-name', serviceName);
							modal.setAttribute('data-label-type', labelType);
						}

						function closeModal() {
							modal.classList.remove('is-open');
							modal.setAttribute('aria-hidden', 'true');
							document.body.classList.remove('pickup-modal-open');
						}

						openButtons.forEach(function (button) {
							button.addEventListener('click', function () {
								openModal(
									button.getAttribute('data-modal-title') || '',
									button.getAttribute('data-service-name') || '',
									button.getAttribute('data-label-type') || 'pickup_point'
								);
							});
						});

						closeButtons.forEach(function (button) {
							button.addEventListener('click', function () {
								closeModal();
							});
						});

						document.addEventListener('keydown', function (event) {
							if (event.key === 'Escape' && modal.classList.contains('is-open')) {
								closeModal();
							}
						});
					});
				</script>

				{{ content_bottom }}
			</div>

			{{ column_right }}
		</div>

	</div>
</main>

{% endapply %}
{{ footer }}