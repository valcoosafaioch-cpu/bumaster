{{ header }}
{% apply spaceless %}
<script type="application/ld+json">
{
	"@context": "http://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
	{% for key, breadcrumb in breadcrumbs %}
		{% if key < breadcrumbs|length - 1 %}
			{% if key == 0 %}
			{% else %}
			{
				"@type": "ListItem",
				"position": {{ key }},
				"item": {
					"@id": "{{ breadcrumb.href }}",
					"name": "{{ breadcrumb.text }}"
				}
			},
			{% endif %}
		{% else %}
			{
				"@type": "ListItem",
				"position": {{ key }},
				"item": {
					"@id": "{{ breadcrumb.href }}",
					"name": "{{ breadcrumb.text }}"
				}
			}
		{% endif %}
	{% endfor %}
	]
}
</script>

{% if column_left and column_right %}
	{% set main = 's12 l6' %}
{% elseif column_left or column_right %}
	{% set main = 's12 l9' %}
{% else %}
	{% set main = 's12' %}
{% endif %}

<main>
	<div class="container">
		<nav id="breadcrumbs" class="breadcrumb-wrapper transparent z-depth-0">
			<span class="breadcrumb-blur hide-on-med-and-up"></span>
			<div class="nav-wrapper breadcrumb-wrap href-underline">
				{% for key, breadcrumb in breadcrumbs %}
					{% if key < breadcrumbs|length - 1 %}
						<a href="{{ breadcrumb.href }}" class="breadcrumb waves-effect black-text">{{ breadcrumb.text }}</a>
					{% else %}
						<span class="breadcrumb blue-grey-text text-darken-3">{{ breadcrumb.text }}</span>
					{% endif %}
				{% endfor %}
			</div>
		</nav>

		<h1>{{ heading_title }}</h1>

		<div class="row">
			{{ column_left }}

			<div class="col {{ main }} section href-underline">
				{{ content_top }}

				<div class="card-panel account-dashboard-card">
					<div class="account-dashboard-top">
						<div class="account-profile-block">
							<div class="account-profile-header">
								<h2>{{ text_profile_title }}</h2>

								<a href="{{ edit }}" class="btn waves-effect waves-light red">
									{{ text_edit_profile }}
								</a>
							</div>

							<div class="account-profile-grid">
								<div class="account-profile-item">
									<div class="account-profile-label">{{ text_lastname }}</div>
									<div class="account-profile-value">{{ lastname }}</div>
								</div>

								<div class="account-profile-item">
									<div class="account-profile-label">{{ text_firstname }}</div>
									<div class="account-profile-value">{{ firstname }}</div>
								</div>

								<div class="account-profile-item">
									<div class="account-profile-label">{{ text_telephone }}</div>
									<div class="account-profile-value">{{ telephone }}</div>
								</div>

								<div class="account-profile-item">
									<div class="account-profile-label">{{ text_email_label }}</div>
									<div class="account-profile-value">{{ email }}</div>
								</div>

								<div class="account-profile-item account-profile-item-newsletter">
									<div class="account-profile-label">{{ text_newsletter_label }}</div>

									<div class="account-profile-newsletter-line">

										<form action="{{ newsletter_action }}" method="post" class="account-newsletter-form">
											<input type="hidden" name="newsletter" value="0">

											<div class="switch">
												<label>

													<span>нет</span>

													<input
														type="checkbox"
														name="newsletter"
														value="1"
														{% if newsletter %}checked="checked"{% endif %}
														onchange="this.form.submit();"
													>

													<span class="lever"></span>

													<span>да</span>

												</label>
											</div>

										</form>

									</div>
								</div>
							</div>
						</div>

						<div class="account-stats-block">
							<h2>{{ text_stats_title }}</h2>

							<div class="account-stats-list">
								<div class="account-stats-item">
									<span class="account-stats-label">{{ text_reward_total }}: </span>
									<span class="account-stats-value">{{ reward_total }}</span>
								</div>

								<div class="account-stats-item">
									<span class="account-stats-label">{{ text_cashback_level }}: </span>
									<span class="account-stats-value">{{ cashback_level }}</span>
								</div>

								<div class="account-stats-item">
									<span class="account-stats-label">{{ text_active_orders }}: </span>
									<span class="account-stats-value">{{ active_orders_total }}</span>
								</div>

								<div class="account-stats-item">
									<span class="account-stats-label">{{ text_total_orders }}: </span>
									<span class="account-stats-value">{{ orders_total }}</span>
								</div>

								<div class="account-stats-item">
									<span class="account-stats-label">{{ text_total_completed_sum }}: </span>
									<span class="account-stats-value">{{ orders_completed_sum }} {{ text_currency_rub_short }}</span>
								</div>
							</div>
						</div>
					</div>

					<div class="account-dashboard-bottom">
						<div class="account-pickup-block">
							<h2>{{ text_pickup_points_title }}</h2>
							<p>{{ text_pickup_points_stub }}</p>

							<a href="{{ pickup_points }}" class="btn-flat waves-effect">
								{{ text_go_to_pickup_points }}
							</a>
						</div>
					</div>
				</div>

				{{ content_bottom }}
			</div>

			{{ column_right }}
		</div>
	</div>
</main>

<script>
document.addEventListener("DOMContentLoaded", function(event) {
	{% if success %}M.toast({html: '<i class="material-icons left">check</i>{{ success }}', classes: 'toast-success'}){% endif %}
});
</script>
{% endapply %}
{{ footer }}